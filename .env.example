# ⚠️ TEMPLATE .env - COPIE PARA .env E PREENCHA COM SUAS CREDENCIAIS
# NUNCA COMMITE O ARQUIVO .env REAL - Já está no .gitignore

# ============================================================================
# TELEGRAM CONFIGURATION
# ============================================================================
# Obtenha do BotFather no Telegram (@BotFather)
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ============================================================================
# BYBIT API CONFIGURATION
# ============================================================================
# Obtenha em https://www.bybit.com/en/user-center/api
# Recomendado: Criar API com permissões read-only para maior segurança
BYBIT_API_KEY=sua_chave_aqui
BYBIT_API_SECRET=seu_secret_aqui

# ============================================================================
# BOT CONFIGURATION
# ============================================================================
# Modo de operação
# - demo: Modo demo (recomendado para testes)
# - testnet: Testnet do Bybit
# - real: Conta real (⚠️ APENAS APÓS TESTES COMPLETOS)
BYBIT_MODE=demo

# Símbolos a tradear (separados por vírgula)
SYMBOLS=BTCUSDT,ETHUSDT,LINKUSDT,XRPUSDT,NEARUSDT

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================
# Intervalo de atualização do dashboard em segundos
# 7200 = 2 horas (padrão)
DASHBOARD_UPDATE_INTERVAL=7200

# Arquivo de log de trades
LOG_FILE=logs/bot_trades.log

# ============================================================================
# BOT PARAMETERS
# ============================================================================
# Percentual de capital a arriscar por trade (1% = 0.01)
RISK_PER_TRADE=0.01

# Stop loss distance em percentual (15% = 0.15)
STOP_LOSS_DISTANCE=0.15

# Saldo inicial para backteste
STARTING_BALANCE=100.0

# ============================================================================
# LOGGING
# ============================================================================
# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. NUNCA COMMITAR .env COM CREDENCIAIS REAIS
# 2. USAR .env.local PARA VARIÁVEIS LOCAIS
# 3. TESTE EM demo ANTES DE USAR real
# 4. BACKUPAR FREQUENTEMENTE
# 5. MONITORAR LOGS REGULARMENTE
